# ══════════════════════════════════════════
#  SiteJudge AI — .gitignore
# ══════════════════════════════════════════

# ── SECRETS (never commit these) ──────────
.env
.env.local
.env.*.local
.env.production
.env.staging

# ── Node / Next.js ─────────────────────────
node_modules/
.next/
.turbo/
dist/
out/
build/
.cache/
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── Python ─────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
*.pyo
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
dist/
*.so
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Docker ─────────────────────────────────
Dockerfile
Dockerfile.*
docker-compose.yml
docker-compose*.yml
.dockerignore

# ── OS ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE / Editor ────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.kate-swp
*.sublime-project
*.sublime-workspace

# ── Logs ────────────────────────────────────
logs/
*.log

# ── Playwright ──────────────────────────────
playwright-report/
test-results/

# ── Coverage / Build artifacts ──────────────
coverage/
.nyc_output/

# ── Misc ────────────────────────────────────
*.pem
*.key
*.cert
