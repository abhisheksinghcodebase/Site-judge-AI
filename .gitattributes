# Normalize line endings to LF on commit, checkout as-is
* text=auto eol=lf

# Force LF for scripts and code
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.py   text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.txt  text eol=lf

# Binaries
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  binary
