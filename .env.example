# ──────────────────────────────────────────────
#  SiteJudge AI — Environment Variables
# ──────────────────────────────────────────────

# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sitejudge:sitejudge@db:5432/sitejudge
POSTGRES_USER=sitejudge
POSTGRES_PASSWORD=sitejudge
POSTGRES_DB=sitejudge

# ── Redis / Celery ────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Lighthouse Worker ─────────────────────────
LIGHTHOUSE_WORKER_URL=http://worker:3001

# ── AI (Groq — llama-3.3-70b-versatile) ──────
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Auth (Clerk) ──────────────────────────────
# Get these from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend CORS ──────────────────────────────
CORS_ORIGINS=http://localhost:3000
